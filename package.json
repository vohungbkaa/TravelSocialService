{
  "name": "travel-social-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:seed:admin": "ts-node src/scripts/seed-admin.ts",
    "tenant:seed:local": "ts-node src/scripts/tenant-seed-local.ts",
    "tenant:create": "ts-node src/scripts/tenant-create.ts",
    "tenant:admin:create": "ts-node src/scripts/tenant-admin-create.ts",
    "tenant:admin:assign": "ts-node src/scripts/tenant-admin-assign.ts",
    "tenant:bootstrap": "ts-node src/scripts/tenant-bootstrap.ts",
    "tenant:seed:base": "ts-node src/scripts/tenant-seed-base.ts",
    "tenant:seed:admins": "ts-node src/scripts/tenant-seed-admins.ts",
    "tenant:seed:categories": "ts-node src/scripts/tenant-seed-categories.ts",
    "tenant:seed:shop": "ts-node src/scripts/tenant-seed-shop.ts",
    "tenant:seed:places": "ts-node src/scripts/tenant-seed-places.ts",
    "tenant:seed:all": "ts-node src/scripts/tenant-seed-all.ts",
    "tenant:delete": "ts-node src/scripts/tenant-delete.ts",
    "db:seed:categories": "ts-node src/scripts/seed-categories.ts",
    "db:seed:areas": "ts-node src/scripts/seed-areas.ts",
    "db:seed:mock-places": "ts-node src/scripts/seed-mock-places.ts",
    "db:seed:all": "npm run db:seed:admin && npm run tenant:seed:all",
    "db:reset:seed": "prisma migrate reset --force && npm run db:seed:all",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.1.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
